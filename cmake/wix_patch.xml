<?xml version="1.0" encoding="utf-8"?>
<CPackWiXPatch>
  <CPackWiXFragment Id="#PRODUCT">
    <!-- Desktop shortcut checkbox property (default: checked) -->
    <Property Id="INSTALLDESKTOPSHORTCUT" Value="1" Secure="yes"/>

    <DirectoryRef Id="IIViewerProgramMenuFolder">
      <Component Id="c_StartMenuShortcut" Guid="*">
        <Shortcut Id="sc_IIViewerStartMenu"
                  Name="IIViewer"
                  Description="ISP Image Viewer"
                  Target="[INSTALL_ROOT]bin\IIViewer.exe"
                  WorkingDirectory="INSTALL_ROOT"
                  Icon="ProductIcon.ico"/>
        <RegistryValue Root="HKCU" Key="Software\IIViewer"
                       Name="StartMenuShortcut" Type="integer"
                       Value="1" KeyPath="yes"/>
        <RemoveFolder Id="rf_IIViewerProgramMenuFolder" On="uninstall"/>
      </Component>
    </DirectoryRef>

    <!-- Desktop shortcut component (placed on user's Desktop) -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="c_DesktopShortcut" Guid="*">
        <Condition>INSTALLDESKTOPSHORTCUT = "1"</Condition>
        <Shortcut Id="sc_IIViewerDesktop"
                  Name="IIViewer"
                  Description="ISP Image Viewer"
                  Target="[INSTALL_ROOT]bin\IIViewer.exe"
                  WorkingDirectory="INSTALL_ROOT"
                  Icon="ProductIcon.ico"/>
        <RegistryValue Root="HKCU" Key="Software\IIViewer"
                       Name="DesktopShortcut" Type="integer"
                       Value="1" KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- Custom UI: insert a dialog with desktop shortcut checkbox
         between InstallDirDlg and VerifyReadyDlg in WixUI_Minimal -->
    <UI>
      <DialogRef Id="DesktopShortcutDlg"/>

      <!-- Redirect InstallDirDlg Next -> DesktopShortcutDlg after the built-in path validation succeeds. -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog"
           Value="DesktopShortcutDlg" Order="5">NOT Installed AND (WIXUI_DONTVALIDATEPATH OR WIXUI_INSTALLDIR_VALID = "1")</Publish>
      <Publish Dialog="DesktopShortcutDlg" Control="Back" Event="NewDialog"
               Value="InstallDirDlg" Order="1">NOT Installed</Publish>
      <Publish Dialog="DesktopShortcutDlg" Control="Next" Event="NewDialog"
               Value="VerifyReadyDlg" Order="1">NOT Installed</Publish>

      <!-- Custom dialog definition -->
      <Dialog Id="DesktopShortcutDlg" Width="370" Height="270"
              Title="[ProductName] Setup" NoMinimize="yes">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="WixUI_Bmp_Banner"/>
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0"/>
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0"/>
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text>{\WixUI_Font_Title}Additional Options</Text>
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text>Select additional installation tasks</Text>
        </Control>
        <Control Id="DesktopShortcutCheckBox" Type="CheckBox" X="25" Y="70"
                 Width="290" Height="17" Property="INSTALLDESKTOPSHORTCUT"
                 CheckBoxValue="1">
          <Text>Create a &amp;desktop shortcut</Text>
        </Control>
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17">
          <Text>&amp;Back</Text>
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes">
          <Text>&amp;Next</Text>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes">
          <Text>Cancel</Text>
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>
    </UI>
  </CPackWiXFragment>

  <CPackWiXFragment Id="#PRODUCTFEATURE">
    <ComponentRef Id="c_StartMenuShortcut"/>
    <ComponentRef Id="c_DesktopShortcut"/>
  </CPackWiXFragment>
</CPackWiXPatch>
